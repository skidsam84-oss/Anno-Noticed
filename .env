# Application
DEBUG=false
LOG_LEVEL=INFO

# Mode Settings
DEFAULT_MODE=auto
AUTO_REPLY_ENABLED=true

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# Languages
DEFAULT_LANGUAGE=en

# Railway specific
PORT=8080
