# Bot Configuration
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ADMIN_IDS=6481759958

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/annopow_db

# OpenAI (Optional)
OPENAI_API_KEY=your_openai_key_here
